{
	"name": "horizon-server",
	"version": "1.0.0",
	"main": "server/app.js",
	"dependencies": {
		"compression": "^1.8.1",
		"cookie-parser": "~1.4.7",
		"express": "^5.2.1",
		"helmet": "^8.1.0",
		"pino": "^10.3.1",
		"pino-http": "^11.0.0"
	},
	"scripts": {
		"start": "node --env-file=.env server/app.js",
		"dev": "node --env-file=.env server/app.js & cd svelte-app && pnpm dev",
		"build": "cd svelte-app && pnpm install && pnpm build",
		"clean": "rm -rf node_modules svelte-app/node_modules svelte-app/.svelte-kit svelte-app/build",
		"format": "prettier --write .",
		"lint": "prettier --check ."
	},
	"engines": {
		"node": ">=24.0.0"
	},
	"packageManager": "pnpm@11.9.0",
	"private": true,
	"devDependencies": {
		"pino-pretty": "^13.1.3",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^4.0.1"
	}
}
