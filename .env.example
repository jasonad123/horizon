# Horizon Environment Variables
# Copy this file to .env and fill in the appropriate values

# Application settings
NODE_ENV=production
PORT=8080

# API Keys
# TRANSIT_API_KEY: Required for accessing the Transit API
# Get your API key from https://transitapp.com/apis
TRANSIT_API_KEY=your_transit_api_key_here

# Security
SESSION_SECRET=change_this_to_a_secure_random_string

# REQUEST_TIMEOUT: API request timeout in milliseconds
REQUEST_TIMEOUT=10000

# Logging
# Options: debug, info, warn, error, fatal
LOG_LEVEL=info

# TRUST_PROXY: set if running behind a reverse proxy (nginx, Caddy, Cloudflare, etc.)
# Values: true, 1, 2 (number of proxy hops)
TRUST_PROXY=

# Cache Configuration
# VITE_REALTIME_CACHE_TTL: Browser cache for real-time prediction data (ms)
VITE_REALTIME_CACHE_TTL=5000

# VITE_STATIC_CACHE_TTL: Browser cache for schedule-only data (ms)
VITE_STATIC_CACHE_TTL=120000

# VITE_CLIENT_POLLING_INTERVAL: How often the board polls for updates (ms)
VITE_CLIENT_POLLING_INTERVAL=10000

# Server-side cache (for multi-display deployments sharing the same stop)
ENABLE_SERVER_CACHE=false
REALTIME_CACHE_TTL=3000
STATIC_CACHE_TTL=120000

# CORS Settings (Development Only)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# Unattended Setup
# When enabled, the board starts immediately using the values below
UNATTENDED_SETUP=true

# UNATTENDED_TITLE: Station or area name shown in the header
UNATTENDED_TITLE="Horizon"

# UNATTENDED_TIME_FORMAT: Options: "HH:mm" (24h), "hh:mm A" (12h with AM/PM)
UNATTENDED_TIME_FORMAT=HH:mm

# UNATTENDED_LOCATION: Latitude and longitude of the display location
# Format: "latitude,longitude" (e.g., "40.7240,-74.0002")
UNATTENDED_LOCATION=

# UNATTENDED_MAX_DISTANCE: Radius to search for nearby routes/stops (meters)
# Options: 250, 500, 750, 1000, 1250, 1500
UNATTENDED_MAX_DISTANCE=500

# UNATTENDED_SELECTED_STOPS: Comma-separated list of global_stop_ids to show.
# When set, the board queries stop_departures for these specific stops/bays/platforms.
# When empty, falls back to nearby_routes using UNATTENDED_LOCATION.
# Example: "STM:88368,STM:88369"
UNATTENDED_SELECTED_STOPS=

# UNATTENDED_MAX_DEPARTURES: Maximum number of rows shown on the board
UNATTENDED_MAX_DEPARTURES=12
